// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String
  hashedPassword String
  details        String
  generalMatchScore GeneralMatchScore[]
  events         Events[]
}

model Corporation {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String
  hashedPassword String?
  details        String
  category       String
  isClaimed      Boolean    @default(false)
  partners       Partners[]
  matchScores    MatchScore[]
  generalMatchScore GeneralMatchScore[]
}

model Events {
  id                   String       @id @default(uuid())
  details              String       @db.Text
  title                String
  date                 DateTime
  country              String
  city                 String
  expectedParticipants Int
  targetSponsorValue   Int
  venue                String 
  organizationID       String
  status               String       @default("pending")
  organization         Organization @relation(fields: [organizationID], references: [id])
  partners             Partners[]
  matchScores          MatchScore[]
  packages             Package[]
}

model Partners {
  eventID       String
  corporationID String
  status        String
  packageID     String?

  event       Events      @relation(fields: [eventID], references: [id])
  corporation Corporation @relation(fields: [corporationID], references: [id])
  package     Package?    @relation(fields: [packageID], references: [id])

  @@id([eventID, corporationID])
}

model Package {
  id        String     @id @default(uuid())
  cost      Int
  title     String     @db.Text
  details   String     @db.Text
  eventID   String
  event     Events     @relation(fields: [eventID], references: [id])
  partners  Partners[]
}

model MatchScore {
  eventID       String
  corporationID String
  score         Float
  reasoning     String? @db.Text
  reasoning_corp String? @db.Text
  event       Events      @relation(fields: [eventID], references: [id])
  corporation Corporation @relation(fields: [corporationID], references: [id])

  @@id([eventID, corporationID])
}

model GeneralMatchScore{
  corporationID String
  organizationID String
  matchScore Float
  reasoning String
  corporation Corporation @relation(fields: [corporationID], references: [id])
  organization Organization @relation(fields: [organizationID], references: [id])

  @@id([corporationID, organizationID])
}